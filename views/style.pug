style.
    * {
    box-sizing: border-box;
    margin: 0;
    font-family: system-ui, Arial, sans-serif;
    }
    body {
    background: #f4f4f4;
    color: #333;
    padding: 20px;
    }
    header {
    background: #222;
    color: #fff;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    }
    nav {
    margin-top: 10px;
    display: flex;
    gap: 15px;
    }
    nav a {
    color: #ddd;
    text-decoration: none;
    font-weight: bold;
    }
    nav a:hover {
    color: #fff;
    }
    main {
    background: #fff;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }
    .section {
    background: #fff;
    padding: 20px;
    border-radius: 8px;
    margin-bottom: 20px;
    max-width: 600px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.08);
    }
    h2 {
    margin-bottom: 15px;
    }
    input {
    width: 100%;
    padding: 12px;
    margin-bottom: 12px;
    border-radius: 6px;
    border: 1px solid #ccc;
    font-size: 1rem;
    }
    input[type="submit"] {
    background: #ff7a18;
    border: none;
    color: #fff;
    font-weight: bold;
    cursor: pointer;
    }
    input[type="submit"]:hover {
    background: #e66a10;
    }
    hr {
    margin: 15px 0;
    }
    .section{
    display: none;
    }
    :target{
    display:block;
    }
    a{
    text-decoration:none;
    color:#303030;
    }
    .products{
    padding:3%;
    border:2px solid red;
    }